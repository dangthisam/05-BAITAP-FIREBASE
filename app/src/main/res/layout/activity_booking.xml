<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:id="@+id/tvBookingMovieTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Tên phim"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="@android:color/black"
        android:gravity="center"
        android:layout_marginBottom="24dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Chọn ghế (Giả lập):"
        android:textSize="16sp"
        android:layout_marginBottom="8dp"/>

    <!-- Giả lập danh sách ghế đơn giản -->
    <CheckBox
        android:id="@+id/cbSeatA1"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Ghế A1 - 150.000đ" />
    <CheckBox
        android:id="@+id/cbSeatA2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Ghế A2 - 150.000đ" />
    <CheckBox
        android:id="@+id/cbSeatB1"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Ghế B1 - 150.000đ" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@android:color/darker_gray"
        android:layout_marginVertical="24dp"/>

    <TextView
        android:id="@+id/tvTotalPrice"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Tổng tiền: 0đ"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="#E91E63"
        android:layout_marginBottom="16dp"/>

    <Button
        android:id="@+id/btnConfirmBooking"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Xác nhận đặt vé"
        android:backgroundTint="#4CAF50"
        android:textColor="@android:color/white"/>

</LinearLayout>
